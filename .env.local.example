# --------------------------------------------------------------------------- #
#  Shopify Storefront API
# --------------------------------------------------------------------------- #
# Your store's *.myshopify.com domain (not the custom domain).
# Found in: Shopify Admin → Settings → Domains
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Public Storefront API access token (safe to expose to the browser).
# Get it from: Shopify Admin → Settings → Apps and sales channels →
#   Develop apps → Create app → Configuration → Storefront API integration →
#   Install app → copy the "Storefront API access token".
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_public_token

# Storefront API version. Shopify ships a new stable version each quarter.
# See: https://shopify.dev/docs/api/usage/versioning
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# --------------------------------------------------------------------------- #
#  Admin API (optional — only needed for private data / webhooks)
# --------------------------------------------------------------------------- #
# Same "Develop apps" page, under "Admin API access token".
# Treat like a password — server-only, never prefix with NEXT_PUBLIC_.
SHOPIFY_ADMIN_API_ACCESS_TOKEN=your_admin_private_token

# --------------------------------------------------------------------------- #
#  Cache revalidation
# --------------------------------------------------------------------------- #
# Any random string — used to authenticate Shopify webhooks hitting
# /api/revalidate. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHOPIFY_REVALIDATION_SECRET=your_random_secret_here
